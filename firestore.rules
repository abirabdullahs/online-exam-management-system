rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /subjects/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /chapters/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /exams/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /questions/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
